FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir uv
COPY . .
RUN uv pip install --system .

CMD ["gunicorn", "gateway.main:app", \
     "-k", "uvicorn.workers.UvicornWorker", \
     "--bind", "0.0.0.0:8000", \
     "--workers", "4", \
     "--threads", "2", \
     "--timeout", "120"]
