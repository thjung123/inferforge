name: "bert_preprocessor"
backend: "python"

input [
  {
    name: "TEXTS"
    data_type: TYPE_STRING
    dims: [ -1 ]
  }
]

output [
  {
    name: "INPUT_IDS"
    data_type: TYPE_INT32
    dims: [ 128 ]
  },
  {
    name: "ATTENTION_MASK"
    data_type: TYPE_INT32
    dims: [ 128 ]
  },
  {
    name: "TOKEN_TYPE_IDS"
    data_type: TYPE_INT32
    dims: [ 128 ]
  }
]

instance_group [{ kind: KIND_CPU }]
max_batch_size: 256
