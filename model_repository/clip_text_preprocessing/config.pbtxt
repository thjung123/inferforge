name: "clip_text_preprocessing"
backend: "python"

input [
  {
    name: "TEXTS"
    data_type: TYPE_STRING
    dims: [ -1 ]
  }
]

output [
  {
    name: "INPUT_IDS"
    data_type: TYPE_INT64
    dims: [ -1, 77 ]
  },
  {
    name: "ATTENTION_MASK"
    data_type: TYPE_INT64
    dims: [ -1, 77 ]
  }
]

instance_group [{ kind: KIND_CPU }]
max_batch_size: 8
